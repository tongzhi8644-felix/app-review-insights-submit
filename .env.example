# Flask App Review Insights — environment template
# Copy to .env and fill in values. Do NOT commit real secrets.

FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-to-a-random-string

# MySQL 8.0.12 (primary)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=app_review_insights

# Optional overrides (leave unset for MySQL):
# DATABASE_URL=mysql+pymysql://root:pass@127.0.0.1:3306/app_review_insights?charset=utf8mb4
# USE_SQLITE=1

# AI — DeepSeek 官方 OpenAI 兼容接口（也可替换为兼容网关）
AI_ENABLED=1
OPENAI_API_KEY=
# Use the /v1 base (not the full .../chat/completions path)
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=8000

# When true, prefer data/cached results for the demo app id if network/model unavailable
ALLOW_CACHED_FALLBACK=1

# Max review pages from Apple RSS (1 page ≈ 50 reviews)
MAX_REVIEW_PAGES=10
